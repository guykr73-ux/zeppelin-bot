# -----------------------------------------------------------------------------
# Zeppelin Cloud Edition - Environment Variables Template
# Copy this file to '.env' and fill in your details for local development.
# -----------------------------------------------------------------------------

# Green API Credentials
GREEN_API_INSTANCE_ID=your_green_api_instance_id_here
GREEN_API_TOKEN=your_green_api_token_here

# AI Provider Configuration
# Set to 'groq' (default) or 'gemini'
AI_PROVIDER=groq

# Groq API Credentials
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Credentials (optional/fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# Encryption Key for Long-Term Memory (Must be 32 characters or random text)
ENCRYPTION_KEY=some_random_secret_32_characters

# Google Cloud Project Configuration (For Firestore)
# When running locally, set this. In GCP Cloud Functions, this is set automatically.
FIRESTORE_PROJECT_ID=your_gcp_project_id_here

# (Optional) If running locally with service account credentials
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
